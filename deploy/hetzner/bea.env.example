# Bea Produktivumgebung für Hetzner
# Diese Datei gehört auf dem Server nach /etc/default/bea.

# Netzwerk
BEA_HOST=127.0.0.1
BEA_PORT=8010

# Sicherheit
BEA_AUTH_REQUIRED=1
BEA_PRIVATE_NETWORK_ONLY=0
BEA_SECURE_COOKIE=1
BEA_TRUST_PROXY_HEADERS=1
BEA_ENABLE_HSTS=1
BEA_ADMIN_MEMBER_IDS=bea

# Datenpfade
# BEA_STATE_PATH=/home/bea/Bea/data/bea_state.json
# BEA_PHOTO_PATH=/home/bea/Bea/data/photos
# BEA_BACKUP_PATH=/home/bea/Bea/data/backups

# E-Mail für Passwort-Reset und Konto-Löschcodes
# BEA_MAIL_HOST=smtp.example.com
# BEA_MAIL_PORT=587
# BEA_MAIL_USER=
# BEA_MAIL_PASS=
# BEA_MAIL_FROM=noreply@example.com
# BEA_MAIL_USE_TLS=1

# Strava
# STRAVA_CLIENT_ID=
# STRAVA_CLIENT_SECRET=
# STRAVA_REDIRECT_URI=https://bea.deinedomain.de/integrationen/strava/callback
